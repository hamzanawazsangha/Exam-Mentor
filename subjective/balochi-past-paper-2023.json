{
  "subject": "Balochi",
  "year": "2023",
  "questions": [
    {
      "question_number": "2",
      "question_text": "\ufe91\ufee0\ufeee\ufb7c\ufbfd \u0632\ufe91\ufe8e\u0646 \ufee3\ufbff\ufe8e\u0646 \u0627\u064f\ufeb3\ufe98\ufee4\ufe8e\ufee7\ufbfd }\ufe91\ufbff\ufee6 \u0627\ufefb\ufed7\ufeee\u0627\ufee3\ufbfd{\u0632\ufe91\ufe8e\ufee7\ufe8e\u06ba \ufb7c\ufee8\ufb91\ufeb2 \u0627\ufe9b\ufeae\ufee3\ufee8\ufeaa \ufb90\u064f\ufeae\ufe97\ufb93\u061f",
      "marks": 20
    },
    {
      "question_number": "3",
      "question_text": "\u064e\ufe91\ufee0\ufeee\ufb7c\ufbfd \ufb90\ufefc\ufeb3\ufbff\ufb91\ufbfd \ufeb7\ufe8e\ufecb\ufeae\u06cc\u0621\u064e \ufeb7\ufba9\ufeaa\u0627\u062f \u0621\u064f \ufee3\ufba9\ufee8\ufe8e\u0632 \u0621\u0650 \u062f\u0627\ufeb3\ufe98\ufe8e\u0646 \u0621\u0650 \ufb7c\ufbaf \u0627\u064e\u0631\u0632\ufeb7\ufe96 \u0627\u0650\ufee7\ufe96\u061f",
      "marks": 20
    },
    {
      "question_number": "4",
      "question_text": "\ufecb\ufec4\ufe8e\ufeb7\ufe8e\u062f\u0627\u0650\u06d2 \u062f\u064e\u0648\u0631 \u0621\u064e \ufe91\ufee0\ufeee\ufb7c\ufbfd \u0632\ufe91\ufe8e\u0646 \u0621\u0650 \ufee3\ufeb4\ufe98\ufeae\ufbfe\ufb9f \ufeb7\ufe8e\ufecb\ufeae \ufb94\u064f\ufeb8\ufb93 \ufe91\ufbff\ufe96\u061f \u0627\u0650\u06d2 \ufe91\ufe8e\ufe91\ufe96 \u0621\u064e \u0648\ufe97\ufbfd \ufea3\ufbff\ufe8e\ufefb\u06ba \u062f\u0631\ufeb7\ufe8e\u0646 \ufb90\ufee6 \u0627\u0650\u062a\u06d4",
      "marks": 20
    },
    {
      "question_number": "5",
      "question_text": "\ufeb7\ufe8c\ufbaf \ufee3\ufeae\ufbfe\ufeaa \u0621\u064f \ufea3\ufe8e\ufee7\ufbfd \u0621\u0650 \ufecb\ufeb8\ufed8\ufbfd \u062f\u0627\ufeb3\ufe98\ufe8e\u0646 \u0621\u0650 \ufeb3\ufeae\u0627 \ufeb3\ufeae\ufe9f\ufee4\ufbff\ufb9f \ufee7\ufe92\ufeb8\ufe98\ufe8e\ufee7\ufb91\ufbaf \ufee7\ufe92\ufeb8\ufe98\u06c1 \ufb90\ufee6 \u0627\u0650\u062a\u06d4",
      "marks": 20
    },
    {
      "question_number": "6",
      "question_text": "\u062f\u0648\u062f \u0621\u064f \u0631\ufe91\ufbff\ufeaa\u06af}\ufe9b\ufed8\ufe8e\ufed3\ufe96{ \ufb7c\ufbaf \u0621\u064e \ufb94\u064f\ufeb8\ufee8\ufe96\u061f \ufe91\ufee0\ufeee\u0686 \u062f\u0648\u062f \u0621\u064f \u0631\ufe91\ufbff\ufeaa\u06af \u0621\u0650 \ufe9f\ufe98\ufe8e\ufe8b\ufbff\ufb9f \ufe97\u064e\ufba9\ufeae\u0627\ufee7\ufbfd \ufeb3\ufeae\u0627 \ufee7\ufe92\ufeb8\ufe98\ufe8e\ufee7\ufb91\ufbaf \ufe91\ufee8\ufeee\ufbfe\ufeb2 \u0627\u0650\u062a\u06d4",
      "marks": 20
    },
    {
      "question_number": "7",
      "question_text": "\u0631\u0650\ufee7\ufeaa \u0621 \ufefb\ufeb7\ufe8e\u0631 \u0621\u0650 \ufee7\ufbff\ufe8e\u0645 \u0621\u064e \ufeb3\ufbfd \ufeb3\ufe8e\ufedf\ufbfd \ufe8b\ufbff\ufb9f \ufe9f\ufee8\ufb93 \u0621\u0650 \ufb58\u064f\ufeb8\ufeaa\u0631\u060c \ufe97\ufe8e\u0648\u0627\u0646 \u0621\u064f \u0622\ufeb3\ufeae \u0621\u0650 \ufe91\ufe8e\ufe91\ufe96 \u0621\u064e \ufeb3\ufeae\ufe9f\ufee4\ufbff\ufb9f \ufee7\ufe92\ufeb8\ufe98\ufe8e\ufee7\ufb91\ufbaf \ufee7\ufe92\ufeb8\ufe98\u06c1 \ufb90\ufee6 \u0627\u0650\u062a\u06d4",
      "marks": 20
    },
    {
      "question_number": "8",
      "question_text": "\ufe9f\ufba9\ufede \u0621\u0650 \u062f\u0627\ufe97\ufb95\ufbff\ufb9f \ufe91\ufee0\ufeee\ufb7c\ufbfd \ufb58\ufbff\ufeae\u0627\ufb94\ufeae\u0627\u0641 \u0621\u064e \u0627\ufee7\ufb95\ufeae\ufbfe\ufeb0\u06cc\u0621\u064e \u0621\u064f \u0627\ufee7\ufb95\ufeae\ufbfe\ufeb0\u06cc \ufb58\ufbff\ufeae\u0627\ufb94\ufeae\u0627\u0641 \ufe91\ufee0\ufeee\ufb7c\ufbfd \u0621\u064e \u0631\u064e\ufe9f\ufe8e\ufee7\ufb8f \ufb90\ufee6 \u0627\u0650\u062a.",
      "marks": 10
    }
  ]
