{
  "subject": "Arabic",
  "year": "2024",
  "questions": [
    {
      "question_number": "2",
      "question_text": "\u0641\u0631\u0642 \u0628\u064a\u0646 \u0627\u0644\u0627\u0633\u0645 \u0627\u0644\u0645\u0641\u0631\u062f \u0648\u0627\u0644\u0645\u062b\u0646\u0649 \u0648\u0627\u0644\u062c\u0645\u0639\u060c \u0645\u0648\u0636\u062d\u064b\u0627 \u0628\u0623\u0646\u0648\u0627\u0639 \u0627\u0644\u062c\u0645\u0639 \u0641\u064a \u0627\u0644\u0644\u063a\u0629 \u0627\u0644\u0639\u0631\u0628\u064a\u0629 \u0648\u0637\u0631\u0642 \u0635\u064a\u0627\u063a\u062a\u0647\u0627 \u0648\u0625\u0639\u0631\u0627\u0628\u0647\u0627\u060c \u0632\u064a\u0646 \u062c\u0648\u0627\u0628\u0643 \u0628\u0627\u0644\u0623\u0645\u062b\u0644\u0629 \u0627\u0644\u0648\u0627\u0641\u064a\u0629.",
      "marks": 20
    },
    {
      "question_number": "3",
      "question_text": "\u0645\u0627 \u0647\u0648 \u0627\u0644\u0627\u0634\u062a\u0642\u0627\u0642 \u0641\u064a \u0627\u0644\u0644\u063a\u0629 \u0627\u0644\u0639\u0631\u0628\u064a\u0629\u061f \u0627\u0630\u0643\u0631 \u062a\u0639\u0631\u064a\u0641\u0647 \u0648\u0623\u0646\u0648\u0627\u0639\u0647 \u0648\u0623\u0645\u062b\u0644\u062a\u0647 \u0628\u0627\u0644\u062a\u0641\u0635\u064a\u0644.",
      "marks": 20
    },
    {
      "question_number": "4",
      "question_text": "\u0644\u0645\u0627\u0630\u0627 \u0633\u0645\u064a \u0627\u0644\u0639\u0635\u0631 \u0627\u0644\u0639\u0628\u0627\u0633\u064a \u0639\u0635\u0631\u064b\u0627 \u0630\u0647\u0628\u064a\u064b\u0627\u061f \u062b\u0645 \u0627\u0630\u0643\u0631 \u0623\u0647\u0645 \u0627\u0644\u0643\u062a\u0628 \u0627\u0644\u0645\u0624\u0644\u0641\u0629 \u0641\u064a \u0627\u0644\u0639\u0635\u0631 \u0627\u0644\u0639\u0628\u0627\u0633\u064a.",
      "marks": 20
    },
    {
      "question_number": "5",
      "question_text": "\u0643\u064a\u0641 \u0623\u062b\u0631 \u0627\u0644\u0642\u0631\u0622\u0646 \u0648\u0627\u0644\u062d\u062f\u064a\u062b \u0639\u0644\u0649 \u0627\u0644\u0623\u062f\u0628 \u0648\u0627\u0644\u0644\u063a\u0629 \u0627\u0644\u0639\u0631\u0628\u064a\u0629\u061f",
      "marks": 20
    },
    {
      "question_number": "6",
      "question_text": "\u0645\u0646 \u0647\u0648 \u0639\u0645\u064a\u062f \u0627\u0644\u0623\u062f\u0628 \u0627\u0644\u0639\u0631\u0628\u064a\u061f \u0627\u0643\u062a\u0628 \u0645\u0627 \u062a\u0639\u0631\u0641 \u0639\u0646 \u0634\u062e\u0635\u064a\u062a\u0647 \u0648\u0623\u0639\u0645\u0627\u0644\u0647.",
      "marks": 20
    },
    {
      "question_number": "7",
      "question_text": "\u0627\u0646\u0633\u0628 \u0627\u0644\u0642\u0635\u064a\u062f\u0629 \u0627\u0644\u062a\u0627\u0644\u064a\u0629 \u0625\u0644\u0649 \u0642\u0627\u0626\u0644\u0647\u0627\u060c \u062b\u0645 \u0627\u0634\u0631\u062d \u0627\u0644\u0623\u0628\u064a\u0627\u062a \u0628\u0623\u0633\u0644\u0648\u0628\u060c \u0645\u0639 \u0630\u0643\u0631 \u0646\u0628\u0630\u0629 \u0639\u0646 \u062d\u064a\u0627\u0629 \u0627\u0644\u0634\u0627\u0639\u0631.\n\u0648\u0644\u062f \u0627\u0644\u0647\u062f\u0649 \u0641\u0627\u0644\u0643\u0627\u0626\u0646\u0627\u062a \u0636\u064a\u0627\u0621 \u0648\u0641\u0645 \u0627\u0644\u0632\u0645\u0627\u0646 \u062a\u0628\u0633\u0645 \u0648\u062b\u0646\u0627\u0621\n\u0627\u0644\u0631\u0648\u062d \u0648\u0645\u0644\u0627\u0621 \u0627\u0644\u0645\u0644\u0627\u0626\u0643 \u062d\u0648\u0644\u0647 \u0644\u0644\u062f\u064a\u0646 \u0648\u0627\u0644\u062f\u0646\u064a\u0627 \u0628\u0634\u0631\u0627\u0621\n\u0641\u064a \u0627\u0644\u0645\u0647\u062f \u064a\u0633\u062a\u0633\u0642\u064a \u0627\u0644\u062d\u064a\u0627 \u0628\u0631\u062c\u0627\u0626\u0647 \u0648\u0628\u0642\u0635\u062f\u0647 \u062a\u0633\u062a\u062f\u0641\u0639 \u0627\u0644\u0628\u0623\u0633\u0627\u0621\n\u0648\u0625\u0630\u0627 \u0623\u062e\u0630\u062a \u0627\u0644\u0639\u0647\u062f \u0623\u0648 \u0623\u0639\u0637\u064a\u062a\u0647 \u0641\u062c\u0645\u064a\u0639 \u0639\u0647\u062f\u0643 \u0630\u0645\u0629 \u0648\u0648\u0641\u0627\u0621\n\u0627\u0644\u062d\u0642 \u0647\u0648 \u0627\u0644\u0623\u0633\u0627\u0633 \u0641\u064a\u0647 \u0648\u0643\u064a\u0641 \u0644\u0627 \u0648\u0627\u0644\u0644\u0647 \u062c\u0644 \u062c\u0644\u0627\u0644\u0647 \u0627\u0644\u0628\u0646\u0627\u0621",
      "marks": 20
    },
    {
