{
  "subject": "Arabic",
  "year": "2021",
  "questions": [
    {
      "question_number": "2",
      "question_text": "\u0643\u064a\u0641 \u062a\u0637\u0648\u0631 \u0627\u0644\u0642\u0635\u0629 \u0627\u0644\u0642\u0635\u064a\u0631\u0629 \u0641\u0649 \u0627\u0644\u0623\u062f\u0628 \u0627\u0644\u0639\u0631\u0628\u0649\u061f \u0627\u0630\u0643\u0631 \u0645\u0639 \u0627\u0644\u062a\u0631\u0643\u064a\u0632 \u0639\u0644\u0649 \u0627\u0644\u0642\u0635\u0635 \u0627\u0644\u0642\u0635\u064a\u0631\u0629 \u0639\u0646\u062f \u0645\u062d\u0645\u0648\u062f \u062a\u064a\u0645\u0648\u0631.",
      "marks": 20
    },
    {
      "question_number": "3",
      "question_text": "\u0645\u0627 \u0647\u064a \u0623\u063a\u0631\u0627\u0636 \u0627\u0644\u0634\u0639\u0631 \u0627\u0644\u062c\u0627\u0647\u0644\u064a\u061f \u0648\u0627\u0630\u0643\u0631 \u0645\u0632\u0627\u064a\u0627\u0647 \u0645\u0639 \u0627\u0644\u062a\u0631\u0643\u064a\u0632 \u0639\u0644\u0649 \u0627\u0644\u0645\u0639\u0644\u0642\u0627\u062a.",
      "marks": 20
    },
    {
      "question_number": "4",
      "question_text": "\u0627\u0643\u062a\u0628 \u0645\u0642\u0627\u0644\u0629 \u062d\u0648\u0644 \u0623\u0633\u0627\u0644\u064a\u0628 \u0627\u0644\u0646\u062b\u0631 \u0627\u0644\u0645\u062e\u062a\u0644\u0641\u0629 \u0641\u0649 \u0627\u0644\u0639\u0635\u0631 \u0627\u0644\u0639\u0628\u0627\u0633\u064a. \u0648\u0627\u0630\u0643\u0631 \u0637\u0628\u0642\u0627\u062a\u0647\u0627 \u0645\u0639 \u0627\u0644\u062a\u0631\u0643\u064a\u0632 \u0639\u0644\u0649 \u0623\u0633\u0644\u0648\u0628 \u0627\u0644\u062c\u0627\u062d\u0638.",
      "marks": 20
    },
    {
      "question_number": "5",
      "question_text": "\u0643\u064a\u0641 \u0643\u0627\u0646 \u0627\u0644\u0634\u0639\u0631 \u0641\u0649 \u0639\u0635\u0631 \u0635\u062f\u0631 \u0627\u0644\u0627\u0633\u0644\u0627\u0645\u061f \u0623\u0644\u0642\u0649 \u0627\u0644\u0636\u0648\u0621 \u0639\u0644\u0649 \u0627\u0644\u062a\u063a\u064a\u0631\u0627\u062a \u0627\u0644\u062a\u0649 \u0638\u0647\u0631\u062a \u0641\u064a\u0647\u0627 \u0628\u0633\u0628\u0628 \u0627\u0644\u0627\u0633\u0644\u0627\u0645.",
      "marks": 20
    },
    {
      "question_number": "6",
      "question_text": "\u0627\u0643\u062a\u0628 \u062a\u0639\u0631\u064a\u0641 \u0627\u0644\u0627\u0633\u0645 \u0648 \u0627\u0634\u0631\u062d \u0623\u0642\u0633\u0627\u0645\u0647 \u0628\u0627\u0644\u0623\u0645\u062b\u0644\u0629 \u0645\u0639 \u0627\u0644\u062a\u0637\u0628\u064a\u0642.",
      "marks": 20
    },
    {
      "question_number": "7",
      "question_text": "\u0627\u0634\u0631\u062d \u0627\u0644\u0623\u0628\u064a\u0627\u062a \u0627\u0644\u062a\u0627\u0644\u064a\u0629 \u0645\u0639 \u0646\u0628\u0630\u0629 \u0648\u062c\u064a\u0632\u0629 \u062d\u0648\u0644 \u062a\u0631\u062c\u0645\u0629 \u0635\u0627\u062d\u0628\u0647\u0627 \u0648 \u062e\u0635\u0627\u0626\u0635 \u0634\u0639\u0631\u0647:\n\n\u0623\u0644\u0627 \u0623\u0628\u0644\u063a \u0623\u0628\u0627 \u0633\u0641\u064a\u0627\u0646 \u0639\u0646\u064a\n\u0641\u0623\u0646\u062a \u0645\u062c\u0648\u0641 \u0646\u062e\u0628 \u0647\u0648\u0627\u0621\n\u0628\u0623\u0646 \u0633\u064a\u0648\u0641\u0646\u0627 \u062a\u0631\u0643\u062a\u0643 \u0639\u0628\u062f\u0627\n\u0648 \u0639\u0628\u062f\u0627\u0644\u062f\u0627\u0631 \u0633\u0627\u062f\u062a\u0647\u0627 \u0627\u0644\u0627\u0645\u0627\u0621\n\u0647\u062d\u0648\u062a \u0645\u062d\u0645\u062f\u0627, \u0641\u0623\u062c\u0628\u062a \u0639\u0646\u0647\n\u0648 \u0639\u0646\u062f \u0627\u0644\u0644\u0647 \u0641\u0649 \u0630\u0627\u0643 \u0627\u0644\u062c\u0632\u0627\u0621\n\u0623 \u062a\u0647\u062c\u0648\u0647, \u0648\u0644\u0633\u062a \u0644\u0647 \u0628\u0643\u0641\u0621\n\u0641\u0634\u0631\u0643\u0645\u0627 \u0644\u062e\u064a\u0631\u0643\u0645\u0627 \u0627\u0644\u0641\u062f\u0627\u0621",
      "marks": 20
    },
    {
      "question_number": "8",
      "question_text": "\u0627\u0643\u062a\u0628 \u0634\u0630\u0631\u0629 \u0639\u0644\u0649 \u0627\u0644\u0645\u0648\u0636\u0648\u0639\u0627\u062a \u0627\u0644\u062a\u0627\u0644\u064a\u0629:\n\n\u0628: \u0642\u0633 \u0628\u0646 \u0633\u0627\u0639\u062f\u0629\n\u0623: \u0627\u0644\u0634\u0627\u0647 \u0648\u0644\u064a \u0627\u0644\u0644\u0647\n\u062f: \u0643\u0644\u064a\u0644\u0629 \u0648 \u062f\u0645\u0646\u0629\n\u062c: \u0627\u0644\u0645\u0642\u0627\u0645\u0627\u062a",
      "marks": 20
    }
